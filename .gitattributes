# Normalize text files to LF in the index and working tree.
* text=auto eol=lf

# Binary means no text conversion, no textual diff, and no EOL handling.
[attr]binary-file binary !eol

# Better built-in diffs for common source formats.
*.cs diff=csharp
*.py diff=python
*.md diff=markdown
*.html diff=html
*.css diff=css
*.js diff=javascript

# Binary image assets.
*.avif binary-file
*.bmp binary-file
*.gif binary-file
*.ico binary-file
*.jpeg binary-file
*.jpg binary-file
*.png binary-file
*.webp binary-file

# Binary font assets.
*.eot binary-file
*.otf binary-file
*.ttf binary-file
*.woff binary-file
*.woff2 binary-file
